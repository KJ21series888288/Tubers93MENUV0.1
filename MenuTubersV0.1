-- SPEED
------------------------------------------------

local SpeedBox = Instance.new("TextBox")
SpeedBox.Parent = PlayerTab
SpeedBox.Size = UDim2.new(0,150,0,40)
SpeedBox.Position = UDim2.new(0,200,0,20)
SpeedBox.PlaceholderText="Speed"
SpeedBox.Text=""
