Tubers93MENU.ZIndexBehavior = Enum.ZIndexBehavior.Global

------------------------------------------------
-- OPEN BUTTON
------------------------------------------------

local Open = Instance.new("ImageButton")
Open.Parent = Tubers93MENU
Open.Size = UDim2.new(0,100,0,80)
Open.Position = UDim2.new(0.5,-50,0,20)
Open.Image = "rbxassetid://140539405777351"
Open.BackgroundTransparency = 1
Open.ZIndex = 9999
Instance.new("UICorner",Open)

------------------------------------------------
-- DRAG OPEN BUTTON
------------------------------------------------

local dragOpen = false
local dragStart
local startPos

Open.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragOpen = true
		dragStart = input.Position
		startPos = Open.Position
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragOpen = false
	end
end)

UIS.InputChanged:Connect(function(input)

	if dragOpen and input.UserInputType == Enum.UserInputType.MouseMovement then

		local delta = input.Position - dragStart

		Open.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)

	end

end)

