SpeedBox.TextColor3=Color3.new(1,1,1)
SpeedBox.ZIndex=20
Instance.new("UICorner",SpeedBox)

SpeedBox.FocusLost:Connect(function()

	local num=tonumber(SpeedBox.Text)

	if num then
		local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if hum then
			hum.WalkSpeed=num
		end
	end

end)

------------------------------------------------
-- ESP
------------------------------------------------

local esp=false
local EspBtn=createButton("ESP",UDim2.new(0,20,0,20),VisualTab)

EspBtn.MouseButton1Click:Connect(function()

	esp = not esp

	for _,p in pairs(Players:GetPlayers()) do

		if p ~= player and p.Character then

			local char=p.Character

			if esp then

				local h=Instance.new("Highlight")
				h.FillTransparency=1
				h.OutlineColor=Color3.new(1,0,0)
				h.Parent=char

			else

				for _,v in pairs(char:GetChildren()) do
					if v:IsA("Highlight") then
						v:Destroy()
					end
				end

			end

		end

	end

end)

------------------------------------------------
-- FULLBRIGHT
------------------------------------------------

local fb=false
local FullBrightBtn=createButton("FullBright",UDim2.new(0,200,0,20),VisualTab)

FullBrightBtn.MouseButton1Click:Connect(function()

	fb = not fb

	if fb then
		Lighting.Brightness=3
		Lighting.ClockTime=12
	else
		Lighting.Brightness=1
	end

end)

------------------------------------------------
-- CAMLOCK (COMBAT)
------------------------------------------------

local camlock=false
local holding=false

local CamlockBtn=createButton("Camlock",UDim2.new(0,20,0,20),CombatTab)

CamlockBtn.MouseButton1Click:Connect(function()
	camlock = not camlock
end)

UIS.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton2 then
		holding=true
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton2 then
		holding=false
	end
end)

RunService.RenderStepped:Connect(function()

	if camlock and holding then

		local closest
		local dist=math.huge

		for _,p in pairs(Players:GetPlayers()) do

			if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then

				local pos,visible = camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)

				if visible then

					local mag=(Vector2.new(pos.X,pos.Y)-camera.ViewportSize/2).Magnitude

					if mag < dist then
						dist = mag
						closest = p
					end

				end

			end

		end

		if closest and closest.Character then

			camera.CFrame = CFrame.new(
				camera.CFrame.Position,
				closest.Character.HumanoidRootPart.Position
			)

		end

	end

end)

------------------------------------------------
-- SONG
------------------------------------------------

local sound = Instance.new("Sound")
sound.SoundId="rbxassetid://132225475210716"
sound.Volume=2
sound.Parent=workspace

local SongBtn=createButton("Tubers93Voice",UDim2.new(0,20,0,20),SongTab)
local LoopBtn=createButton("Tubers93VoiceLoop",UDim2.new(0,200,0,20),SongTab)

SongBtn.MouseButton1Click:Connect(function()
	sound.Looped=false
	sound:Play()
end)

local loop=false

LoopBtn.MouseButton1Click:Connect(function()

	loop = not loop
	sound.Looped = loop

	if loop then
		sound:Play()
	else
		sound:Stop()
	end

end)
