------------------------------------------------
-- BUTTON CREATOR
------------------------------------------------

local function createButton(text,pos,parent)

	local b = Instance.new("TextButton")
	b.Parent = parent
	b.Size = UDim2.new(0,150,0,40)
	b.Position = pos
	b.Text = text
	b.Font = Enum.Font.SourceSansBold
	b.TextScaled = true
	b.BackgroundColor3 = Color3.fromRGB(255,0,0)
	b.TextColor3 = Color3.new(1,1,1)
	b.ZIndex = 20
	Instance.new("UICorner",b)

	return b

end

