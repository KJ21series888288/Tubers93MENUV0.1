-- SOUND
------------------------------------------------

local sound = Instance.new("Sound")
sound.SoundId = "rbxassetid://132225475210716"
sound.Volume = 5
sound.Parent = workspace

------------------------------------------------
-- PLAY ONCE
------------------------------------------------

VoiceButton.MouseButton1Click:Connect(function()

	sound.Looped = false
	sound:Play()

end)

------------------------------------------------
-- LOOP
------------------------------------------------

local loop = false

VoiceLoopButton.MouseButton1Click:Connect(function()

	loop = not loop

	sound.Looped = loop

	if loop then
		sound:Play()
	else
		sound:Stop()
	end

end)
